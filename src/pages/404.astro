---
import { Icon } from "astro-icon/components";
import I18nKey from "@/i18n/i18nKey";
import { i18n } from "@/i18n/translation";
import MainGridLayout from "@/layouts/MainGridLayout.astro";
import { getSortedPostsList } from "@/utils/content-utils";
import { formatDateToYYYYMMDD } from "@/utils/date-utils";
import { url } from "@/utils/url-utils";

const recentPosts = (await getSortedPostsList()).slice(0, 5);
---

<MainGridLayout title={i18n(I18nKey.notFound)} description={i18n(I18nKey.notFoundDescription)}>
    <div class="flex w-full rounded-(--radius-large) overflow-hidden relative min-h-96">
        <div class="card-base z-10 px-9 py-12 relative w-full flex flex-col items-center justify-center text-center">
            <!-- 404 大号数字 -->
            <div class="text-8xl md:text-9xl font-bold text-(--primary) opacity-20 mb-4">
                {i18n(I18nKey.notFound)}
            </div>
            
            <!-- 404 图标 -->
            <div class="mb-6">
                <Icon name="material-symbols:error-outline" class="text-6xl text-(--primary)" />
            </div>
            
            <!-- 标题 -->
            <div class="text-3xl md:text-4xl font-bold mb-4 text-90">
                {i18n(I18nKey.notFoundTitle)}
            </div>
            
            <!-- 描述 -->
            <p class="text-lg text-75 mb-8 max-w-md">
                {i18n(I18nKey.notFoundDescription)}
            </p>
            
            <!-- 快捷入口 -->
            <div class="flex flex-wrap items-center justify-center gap-3">
                <a
                    href={url("/")}
                    class="inline-flex items-center gap-2 px-6 py-3 bg-(--primary) text-white rounded-(--radius-large) hover:bg-(--btn-content) transition-colors duration-200 font-medium"
                >
                    <Icon name="material-symbols:home" class="text-xl" />
                    {i18n(I18nKey.backToHome)}
                </a>
                <a
                    href={url("/search/")}
                    class="inline-flex items-center gap-2 px-6 py-3 btn-regular rounded-(--radius-large) font-medium"
                >
                    <Icon name="material-symbols:search" class="text-xl" />
                    {i18n(I18nKey.search)}
                </a>
                <a
                    href={url("/archive/")}
                    class="inline-flex items-center gap-2 px-6 py-3 btn-regular rounded-(--radius-large) font-medium"
                >
                    <Icon name="material-symbols:archive-outline" class="text-xl" />
                    {i18n(I18nKey.archive)}
                </a>
            </div>
            
            <!-- 装饰性元素 -->
            <div class="absolute top-4 left-4 opacity-10">
                <Icon name="material-symbols:sentiment-sad" class="text-4xl text-(--primary)" />
            </div>
            <div class="absolute bottom-4 right-4 opacity-10">
                <Icon name="material-symbols:search-off" class="text-4xl text-(--primary)" />
            </div>
        </div>
    </div>

    {recentPosts.length > 0 && (
        <div class="card-base rounded-(--radius-large) px-9 py-6 mt-4 onload-animation">
            <h2 class="text-xl font-bold text-90 mb-4 flex items-center gap-2">
                <Icon name="material-symbols:article-outline" class="text-(--primary) text-2xl" />
                {i18n(I18nKey.recentPosts)}
            </h2>
            <div class="flex flex-col gap-1">
                {recentPosts.map((post) => (
                    <a
                        href={url(`/posts/${post.id}/`)}
                        class="group flex items-center justify-between gap-4 px-3 py-2.5 rounded-lg hover:bg-(--btn-plain-bg-hover) transition-colors"
                    >
                        <span class="font-medium text-75 group-hover:text-(--primary) transition-colors truncate">
                            {post.data.title}
                        </span>
                        <time
                            datetime={post.data.published.toISOString()}
                            class="text-sm text-50 shrink-0"
                        >
                            {formatDateToYYYYMMDD(post.data.published)}
                        </time>
                    </a>
                ))}
            </div>
        </div>
    )}
</MainGridLayout>

<style>
    /* 添加一些动画效果 */
    .card-base {
        animation: fadeInUp 0.6s ease-out;
    }
    
    @keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
    
    /* 按钮悬停效果 */
    a:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(var(--primary-rgb), 0.3);
    }
</style>