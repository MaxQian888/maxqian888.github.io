---

import { getEntry, render } from "astro:content";
import ImageWrapper from "@components/common/ImageWrapper.astro";
import Markdown from "@components/common/Markdown.astro";
import { Icon } from "astro-icon/components";
import { profileConfig } from "@/config/profileConfig";
import I18nKey from "@/i18n/i18nKey";
import { i18n } from "@/i18n/translation";
import MainGridLayout from "@/layouts/MainGridLayout.astro";
import {
	getCategoryList,
	getSortedPosts,
	getTagList,
} from "@/utils/content-utils";

const aboutPost = await getEntry("spec", "about");

if (!aboutPost) {
	throw new Error("About page content not found");
}

const { Content } = await render(aboutPost);

const posts = await getSortedPosts();
const categories = await getCategoryList();
const tags = await getTagList();

let totalWords = 0;
for (const post of posts) {
	if (post.body) {
		const text = post.body
			.replace(/```[\s\S]*?```/g, "")
			.replace(/`[^`]*`/g, "")
			.replace(/\s+/g, " ")
			.trim();
		const chineseChars = text.match(/[一-龥]/g) || [];
		const englishChars = text.match(/[a-zA-Z]/g) || [];
		totalWords += chineseChars.length + englishChars.length;
	}
}

// 技术栈展示，替代 markdown 中的 shields.io 外链徽章
const techStack = [
	{
		name: "C++",
		icon: "simple-icons:cplusplus",
		color: "#00599C",
		desc: "高性能与系统开发",
	},
	{
		name: "C",
		icon: "simple-icons:c",
		color: "#A8B9CC",
		desc: "底层与嵌入式",
	},
	{
		name: "Python",
		icon: "simple-icons:python",
		color: "#3776AB",
		desc: "数据处理与脚本",
	},
	{
		name: "TypeScript",
		icon: "simple-icons:typescript",
		color: "#3178C6",
		desc: "类型安全的前端",
	},
	{
		name: "JavaScript",
		icon: "simple-icons:javascript",
		color: "#E8C31E",
		desc: "Web 开发",
	},
	{
		name: "Qt",
		icon: "simple-icons:qt",
		color: "#41CD52",
		desc: "跨平台 GUI 框架",
	},
	{
		name: "Git",
		icon: "simple-icons:git",
		color: "#F05032",
		desc: "版本控制",
	},
	{
		name: "GitHub",
		icon: "simple-icons:github",
		color: "",
		desc: "开源协作",
	},
	{
		name: "VS Code",
		icon: "simple-icons:vscodium",
		color: "#2F80ED",
		desc: "主力编辑器",
	},
	{
		name: "CLion",
		icon: "simple-icons:clion",
		color: "#21D789",
		desc: "C/C++ IDE",
	},
	{
		name: "PyCharm",
		icon: "simple-icons:pycharm",
		color: "#FCB414",
		desc: "Python IDE",
	},
	{
		name: "CMake",
		icon: "simple-icons:cmake",
		color: "#064F8C",
		desc: "构建系统",
	},
];

const stats = [
	{
		icon: "material-symbols:article-outline",
		label: i18n(I18nKey.siteStatsPostCount),
		value: posts.length.toLocaleString(),
	},
	{
		icon: "material-symbols:folder-outline",
		label: i18n(I18nKey.siteStatsCategoryCount),
		value: categories.length.toLocaleString(),
	},
	{
		icon: "material-symbols:label-outline",
		label: i18n(I18nKey.siteStatsTagCount),
		value: tags.length.toLocaleString(),
	},
	{
		icon: "material-symbols:text-ad-outline-rounded",
		label: i18n(I18nKey.siteStatsTotalWords),
		value: totalWords.toLocaleString(),
	},
];
---
<MainGridLayout title={i18n(I18nKey.about)} description={i18n(I18nKey.about)}>
    <!-- Profile hero -->
    <div class="card-base rounded-(--radius-large) overflow-hidden relative mb-4 onload-animation">
        <div class="absolute inset-x-0 top-0 h-28 bg-gradient-to-b from-(--primary)/15 to-transparent pointer-events-none"></div>
        <div class="relative px-9 pt-10 pb-6 flex flex-col md:flex-row items-center md:items-end gap-6">
            <div class="w-28 h-28 rounded-full overflow-hidden ring-4 ring-(--primary)/30 shrink-0 shadow-lg">
                <ImageWrapper
                    src={profileConfig.avatar || ""}
                    alt={`Avatar of ${profileConfig.name}`}
                    class="w-full h-full object-cover"
                    widths={[112, 224]}
                    sizes="112px"
                />
            </div>
            <div class="flex flex-col items-center md:items-start gap-1.5 text-center md:text-left">
                <h1 class="text-3xl font-bold text-90">{profileConfig.name}</h1>
                <p class="text-75">{profileConfig.bio}</p>
                <div class="flex flex-wrap gap-2 mt-1 justify-center md:justify-start">
                    {profileConfig.links
                        .filter((item) => !item.url.startsWith("mailto:"))
                        .map((item) => (
                            <a
                                rel="me"
                                aria-label={item.name}
                                href={item.url}
                                target="_blank"
                                class="btn-regular rounded-lg h-9 w-9 active:scale-90"
                            >
                                <Icon name={item.icon} class="text-[1.25rem]" />
                            </a>
                        ))}
                </div>
            </div>
        </div>
        <!-- Stats strip -->
        <div class="grid grid-cols-2 md:grid-cols-4 border-t border-black/5 dark:border-white/5">
            {stats.map((stat) => (
                <div class="flex flex-col items-center gap-1 py-4 px-2">
                    <div class="flex items-center gap-1.5 text-(--primary)">
                        <Icon name={stat.icon} class="text-lg" />
                        <span class="text-xl font-bold text-90">{stat.value}</span>
                    </div>
                    <span class="text-xs text-50">{stat.label}</span>
                </div>
            ))}
        </div>
    </div>

    <!-- Tech stack -->
    <div class="card-base rounded-(--radius-large) px-9 py-6 mb-4 onload-animation">
        <div class="flex items-center gap-3 mb-1">
            <div class="h-8 w-8 rounded-lg bg-(--primary)/10 flex items-center justify-center">
                <Icon name="material-symbols:stacks-outline-rounded" class="text-[1.25rem] text-(--primary)" />
            </div>
            <h2 class="text-xl font-bold text-90">{i18n(I18nKey.techStack)}</h2>
        </div>
        <p class="text-sm text-50 mb-5">{i18n(I18nKey.techStackDesc)}</p>
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3">
            {techStack.map((tech) => (
                <div class="tech-item group flex items-center gap-3 p-3 rounded-xl border border-(--line-divider) hover:border-(--primary)/50 hover:shadow-lg transition-all duration-300">
                    <div
                        class="w-10 h-10 rounded-lg bg-(--btn-regular-bg) flex items-center justify-center shrink-0 group-hover:scale-110 transition-transform duration-300 text-90"
                        style={tech.color ? `color: ${tech.color};` : undefined}
                    >
                        <Icon name={tech.icon} class="text-[1.35rem]" />
                    </div>
                    <div class="min-w-0">
                        <div class="font-semibold text-sm text-90 truncate">{tech.name}</div>
                        <div class="text-xs text-50 truncate">{tech.desc}</div>
                    </div>
                </div>
            ))}
        </div>
    </div>

    <!-- About content -->
    <div class="flex w-full rounded-(--radius-large) overflow-hidden relative min-h-32 onload-animation">
        <div class="card-base z-10 px-9 py-6 relative w-full ">
            <Markdown class="mt-2">
                <Content />
            </Markdown>
        </div>
    </div>
</MainGridLayout>

<style>
    .tech-item:hover {
        transform: translateY(-2px);
    }
</style>
